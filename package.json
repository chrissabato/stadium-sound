{
  "name": "stadium-sound",
  "productName": "Stadium Sound",
  "version": "0.5.0",
  "description": "Stadium Sound",
  "author": "Christopher Sabato",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm test && npm run build",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.8.9",
    "music-metadata": "^10.5.0",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/qrcode-generator": "^0.0.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright-core": "^1.61.1",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
